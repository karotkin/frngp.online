# --- веб (nginx) ---
WEB_PORT=8092

# --- вход на сайт (HTTP Basic Auth) ---
# пароль хранится в контейнере bcrypt-хэшем; меняйте на свой
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# --- курс валют (rate-api) ---
RATE_TTL_MIN=30

# --- postgres ---
POSTGRES_USER=frngp
POSTGRES_PASSWORD=frngp_pass
POSTGRES_DB=frngp
DB_PORT=5432
